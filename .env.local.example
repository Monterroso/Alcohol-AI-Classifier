NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for Next routes, uploads, and worker writes.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string used only by npm run db:setup.
SUPABASE_DB_URL=


# Local document-intelligence worker.
WORKER_ID=local-orchestrator
POLL_MS=1000
WORKER_BATCH_SIZE=3
APPLICATION_CONCURRENCY=2
IMAGE_CONCURRENCY=3

# Azure AI Document Intelligence.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-read
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Field extraction. Use deterministic for the fast OCR/fuzzy path, hybrid for deterministic + LLM fallback, or openai/gemini for direct LLM extraction.
EXTRACTION_MODE=deterministic
EXTRACTION_PROVIDER=gemini
FALLBACK_OCR_BLOCK_LIMIT=80

# Optional OpenAI structured extraction. Set EXTRACTION_MODE=openai or hybrid to use it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional Gemini structured extraction. Set EXTRACTION_MODE=gemini or EXTRACTION_MODE=hybrid with EXTRACTION_PROVIDER=gemini to use it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
